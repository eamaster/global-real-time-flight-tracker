# ─────────────────────────────────────────────
# Frontend environment variables — example file
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Mapbox Access Token (required)
# Get yours at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Backend API URL
# ┌─ Local development ──────────────────────────────────────────────┐
# │ Leave empty so Vite proxy forwards /api/* → http://localhost:3001 │
# └──────────────────────────────────────────────────────────────────┘
VITE_API_URL=

# ┌─ Production (Cloudflare Worker) ─────────────────────────────────┐
# │ VITE_API_URL=https://global-flight-tracker-api.<worker>.workers.dev │
# └──────────────────────────────────────────────────────────────────┘

# Base path for the app
# '/'                              → localhost / custom domain
# '/global-real-time-flight-tracker/' → GitHub Pages
VITE_BASE_PATH=/
